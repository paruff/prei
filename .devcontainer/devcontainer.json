{
  "name": "prei — Django 5.2 (SQLite dev, Postgres optional)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "web",
  "runServices": [
    "web"
  ],
  "workspaceFolder": "/workspaces/prei",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2"
    }
  },
  "shutdownAction": "stopCompose",
  "forwardPorts": [
    8000
  ],
  "portsAttributes": {
    "8000": {
      "label": "Django app",
      "onAutoForward": "notify"
    }
  },
  "containerEnv": {
    "DJANGO_SETTINGS_MODULE": "investor_app.settings",
    "DATABASE_URL": "sqlite:////home/vscode/db.sqlite3",
    "SECRET_KEY": "dev-secret-key-change-me",
    "DEBUG": "True",
    "ALLOWED_HOSTS": "*",
    "RUN_MIGRATIONS": "1"
  },
  "remoteEnv": {
    "CODESPACE_NAME": "${localEnv:CODESPACE_NAME}",
    "GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN": "${localEnv:GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN}",
    "GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN_GITHUB_DEV": "${localEnv:GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN_GITHUB_DEV}"
  },
  "postCreateCommand": "pip install --upgrade pip 'setuptools>=82' 'wheel>=0.46.2' && pip install -r requirements.txt && python manage.py migrate --noinput",
  "postStartCommand": "python manage.py check",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "-q"
        ],
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
