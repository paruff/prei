# Set DJANGO_ENV=production in production deployments to enable hardened defaults.
DJANGO_ENV=production
DEBUG=False
SECRET_KEY=replace-with-a-secure-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY
LOG_LEVEL=INFO

# Default Codespaces/devcontainer database settings.
# The devcontainer starts PostgreSQL as the `db` service with these credentials.
POSTGRES_DB=prei
POSTGRES_USER=prei
POSTGRES_PASSWORD=prei
DATABASE_URL=postgres://prei:prei@db:5432/prei

# Financial defaults
VACANCY_RATE=0.05
MANAGEMENT_FEE_RATE=0.08
CAPEX_RESERVE_RATE=0.05

# Data source API keys
ATTOM_API_KEY=your_attom_api_key_here

# Optional Redis/Celery settings for non-devcontainer deployments
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Data source monitoring
ATTOM_MONTHLY_BUDGET=1000.00
ATTOM_COST_PER_CALL=0.01
