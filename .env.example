# =============================================================================
# prei Environment Configuration
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# See docs/ for environment-specific guides:
#   docs/how-to-guides/local-dev.md       — Local Docker (dev)
#   docs/how-to-guides/devcontainer.md    — Codespaces (test)
#   docs/how-to-guides/render-deploy.md   — Render (prod)
# =============================================================================


# -----------------------------------------------------------------------------
# Django Environment
# -----------------------------------------------------------------------------
# Controls which security defaults are active.
#
# local/dev:     DJANGO_ENV=development, DEBUG=True
# devcontainer:  Already set in devcontainer.json (DEBUG=True)
# render/prod:   DJANGO_ENV=production, DEBUG=False
# -----------------------------------------------------------------------------
DJANGO_ENV=production
DEBUG=False


# -----------------------------------------------------------------------------
# Secret Key
# -----------------------------------------------------------------------------
# Required. Must be set before the app will start.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# Never commit a real secret key to version control.
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-a-secure-random-secret


# -----------------------------------------------------------------------------
# Allowed Hosts
# -----------------------------------------------------------------------------
# Comma-separated list of hostnames Django will serve.
#   local/dev:     localhost,127.0.0.1,0.0.0.0
#   devcontainer:  Set to * in devcontainer.json
#   render/prod:   your-app.onrender.com (set in Render dashboard)
# -----------------------------------------------------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0


# -----------------------------------------------------------------------------
# HTTPS / Security Settings
# -----------------------------------------------------------------------------
# These default to secure values. For local HTTP usage:
#   SECURE_SSL_REDIRECT=False
#   CSRF_COOKIE_SECURE=False
#   SESSION_COOKIE_SECURE=False
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Default: SQLite (db.sqlite3). No external service needed.
# Render injects DATABASE_URL automatically from its managed PostgreSQL.
# -----------------------------------------------------------------------------
# DATABASE_URL=postgres://user:pass@host:5432/prei


# -----------------------------------------------------------------------------
# Financial Defaults
# -----------------------------------------------------------------------------
# Override to match your local market assumptions.
# -----------------------------------------------------------------------------
VACANCY_RATE=0.05
MANAGEMENT_FEE_RATE=0.08
CAPEX_RESERVE_RATE=0.05


# -----------------------------------------------------------------------------
# Data Source API Keys
# -----------------------------------------------------------------------------
# These keys power property data, market intelligence, and neighborhood
# quality features. Leave blank if you do not need that feature.
#
# See docs/reference/api-keys.md for full details and signup links.
# -----------------------------------------------------------------------------

# Property data, comps, foreclosures — https://api.attomdata.com
ATTOM_API_KEY=your_attom_api_key_here

# ZIP demographics (population, income, growth) — https://api.census.gov
CENSUS_API_KEY=your_census_api_key_here

# Unemployment, wage data — https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# Rental estimates — https://rentcast.io
RENTCAST_API_KEY=your_rentcast_api_key_here

# School ratings — https://greatschools.org/api
GREATSCHOOLS_API_KEY=your_greatschools_api_key_here

# Walkability scores — https://walkscore.com/professional/api
WALKSCORE_API_KEY=your_walkscore_api_key_here


# -----------------------------------------------------------------------------
# ATTOM API Spend Monitoring
# -----------------------------------------------------------------------------
# Controls spend limits for the ATTOM API to prevent unexpected charges.
# -----------------------------------------------------------------------------
ATTOM_MONTHLY_BUDGET=1000.00
ATTOM_COST_PER_CALL=0.01
