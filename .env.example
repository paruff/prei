# =============================================================================
# prei Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values before running.
#
#   cp .env.example .env
#
# See docs/how-to-guides/docker-local-setup.md for full setup instructions.
# =============================================================================


# -----------------------------------------------------------------------------
# Django Environment
# -----------------------------------------------------------------------------
# Controls which security defaults are active.
#
# ⚠️  LOCAL DOCKER USERS: You must change these four settings or the app will
#     redirect all traffic to https:// and refuse to serve pages in a browser.
#
#   DJANGO_ENV=development
#   DEBUG=True
#
# Leave as-is for production deployments.
# -----------------------------------------------------------------------------
DJANGO_ENV=production
DEBUG=False


# -----------------------------------------------------------------------------
# Secret Key
# -----------------------------------------------------------------------------
# Required. Must be set before the app will start.
# Generate a value with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# Never commit a real secret key to version control.
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-a-secure-random-secret


# -----------------------------------------------------------------------------
# Allowed Hosts
# -----------------------------------------------------------------------------
# Comma-separated list of hostnames Django will serve.
# For local use, localhost and 127.0.0.1 are sufficient.
# For local Docker development, include 0.0.0.0 because the container
# binds to 0.0.0.0 and receives requests with that Host header.
# In production, set to your actual domain (e.g. prei.example.com).
# -----------------------------------------------------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CSRF_TRUSTED_ORIGINS is automatically computed from ALLOWED_HOSTS +
# Codespace auto-detection + local dev defaults. In production behind a
# TLS-terminating proxy (Render, Fly.io, etc.), explicitly set:
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com


# -----------------------------------------------------------------------------
# HTTPS / Security Settings
# -----------------------------------------------------------------------------
# When DEBUG=False, these settings default to secure values.
#
# For local HTTP usage, set DEBUG=True.
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Default: SQLite (db.sqlite3 in project root).  No external service needed.
# Postgres is reserved for post-MVP production deployment.
#
# To switch to Postgres (e.g. for production):
#   1. Uncomment the DATABASE_URL and POSTGRES_* lines below.
#   2. Uncomment the db service in docker-compose.yml.
#   3. Rebuild: docker compose build web && docker compose up -d web
# -----------------------------------------------------------------------------
# POSTGRES_DB=prei
# POSTGRES_USER=prei
# POSTGRES_PASSWORD=prei
# DATABASE_URL=postgres://prei:prei@db:5432/prei


# -----------------------------------------------------------------------------
# Financial Defaults
# -----------------------------------------------------------------------------
# Default rates used in investment KPI calculations.
# Override to match your local market assumptions.
# -----------------------------------------------------------------------------
VACANCY_RATE=0.05
MANAGEMENT_FEE_RATE=0.08
CAPEX_RESERVE_RATE=0.05


# -----------------------------------------------------------------------------
# Data Source API Keys
# -----------------------------------------------------------------------------
# ATTOM Data Solutions API key for property and foreclosure data.
# Sign up at https://api.attomdata.com to obtain a key.
# Leave as-is if you do not need live property data.
# -----------------------------------------------------------------------------
ATTOM_API_KEY=your_attom_api_key_here

# -----------------------------------------------------------------------------
# Census & BLS API Keys (Phase 0 — Market Indicators)
# -----------------------------------------------------------------------------
# Census API key for ZIP-level demographics (population, income, growth).
# Free registration at https://api.census.gov
# -----------------------------------------------------------------------------
CENSUS_API_KEY=your_census_api_key_here

# BLS API key for state-level unemployment data.
# Free registration at https://data.bls.gov/registrationEngine/
# -----------------------------------------------------------------------------
BLS_API_KEY=your_bls_api_key_here

# -----------------------------------------------------------------------------
# RentCast API key for rental estimates.
# Free registration at https://rentcast.io
# -----------------------------------------------------------------------------
RENTCAST_API_KEY=your_rentcast_api_key_here

# -----------------------------------------------------------------------------
# GreatSchools API key for school ratings.
# Free registration at https://greatschools.org/api
# -----------------------------------------------------------------------------
GREATSCHOOLS_API_KEY=your_greatschools_api_key_here

# -----------------------------------------------------------------------------
# Walk Score API key for walkability scores.
# Free registration at https://walkscore.com/professional/api
# -----------------------------------------------------------------------------
WALKSCORE_API_KEY=your_walkscore_api_key_here


# -----------------------------------------------------------------------------
# Data Source Monitoring
# -----------------------------------------------------------------------------
# Controls spend limits for the ATTOM API.
# Adjust based on your API plan limits.
# -----------------------------------------------------------------------------
ATTOM_MONTHLY_BUDGET=1000.00
ATTOM_COST_PER_CALL=0.01
